# Configuration Example for Kali MCP Tactical Server
# Copy this file to .env and fill in your actual values

# OpenRouter API Key (for AI integration)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Configuration
DB_PATH=/tmp/kali_mcp_tactical.db
CACHE_EXPIRY_HOURS=24

# Scanner Configuration
MAX_OUTPUT_CHARS=2000
SCAN_TIMEOUT=300
MAX_PARALLEL_TASKS=10

# Tool Paths (Auto-detected if in PATH)
NAABU_PATH=/usr/local/bin/naabu
HTTPX_PATH=/usr/local/bin/httpx
NUCLEI_PATH=/usr/local/bin/nuclei
FFUF_PATH=/usr/local/bin/ffuf
SUBFINDER_PATH=/usr/local/bin/subfinder

# Wordlists
WORDLIST_WEB_DIRS=/usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt
WORDLIST_PASSWORDS=/usr/share/wordlists/rockyou.txt
WORDLIST_SUBDOMAINS=/usr/share/wordlists/subdomains/top1million.txt

# Evasion & Stealth
ENABLE_PROXY_ROTATION=false
TOR_PROXY=socks5://127.0.0.1:9050
ENABLE_RATE_LIMITING=true
DEFAULT_SCAN_INTENSITY=fast

# IP Pool for Distributed Attacks (comma-separated)
IP_POOL=socks5://127.0.0.1:9050,socks5://127.0.0.1:9052,socks5://127.0.0.1:9053

# Advanced Options
ENABLE_GHOST_MODE=true
MIKROTIK_STEALTH_MODE=true
AUTO_ROTATE_IP_ON_BAN=true
